# --- Directus core (used by docker-compose.yml) ---
KEY=replace-with-a-random-uuid
SECRET=replace-with-a-long-random-secret

DB_CLIENT=pg
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=directus
DB_USER=directus
DB_PASSWORD=directus

CACHE_ENABLED=false
CACHE_STORE=redis
REDIS=redis://redis:6379

ADMIN_EMAIL=admin@pintogather.dev
ADMIN_PASSWORD=replace-with-a-strong-password

PUBLIC_URL=http://localhost:8055
CORS_ENABLED=true
CORS_ORIGIN=http://localhost:5000

STORAGE_LOCATIONS=local
STORAGE_LOCAL_ROOT=./uploads

# Direct Postgres connection (host-mapped port), used only by
# schema/constraints.ts to add composite unique indexes Directus's schema
# API can't express, run from the host (not inside the container).
DATABASE_URL=postgresql://directus:directus@localhost:5432/directus

# Long-lived static token used by the Express server to talk to Directus as
# the narrowly-scoped "Service" role (see src/permissions/definitions.ts) —
# never admin, never exposed to the browser. Generated by
# `npm --prefix directus run permissions:apply` on first run and printed to
# the console — paste it here and into the app's root .env as
# DIRECTUS_SERVICE_TOKEN.
# SERVICE_TOKEN=

# Comma-separated list of emails that should be granted is_admin=true on
# their directus_users row the first time they sign in via Clerk.
ADMIN_EMAILS=kipergil@gmail.com
