# --- Connecting the schema/permissions tooling to Directus ---
# Point this at either a local docker-compose stack (http://localhost:8055)
# or an existing/hosted Directus instance. Either way, the schema tooling
# only creates PinTogather's own collections and a distinctly-named
# "PinTogather Service" policy/role — it never touches collections,
# policies, or roles it didn't create, so a shared/hosted instance used by
# other projects is safe to point this at.
DIRECTUS_URL=http://localhost:8055
ADMIN_EMAIL=admin@pintogather.dev
ADMIN_PASSWORD=replace-with-a-strong-password

# --- Directus core (used by docker-compose.yml for a local stack only —
# not needed when DIRECTUS_URL points at an existing hosted instance) ---
KEY=replace-with-a-random-uuid
SECRET=replace-with-a-long-random-secret

DB_CLIENT=pg
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=directus
DB_USER=directus
DB_PASSWORD=directus

CACHE_ENABLED=false
CACHE_STORE=redis
REDIS=redis://redis:6379

PUBLIC_URL=http://localhost:8055
CORS_ENABLED=true
CORS_ORIGIN=http://localhost:5000

STORAGE_LOCATIONS=local
STORAGE_LOCAL_ROOT=./uploads

# Direct Postgres connection, used only by schema/constraints.ts to add a
# composite unique index Directus's schema API can't express. Optional —
# skipped with a warning if unset (e.g. a managed instance that doesn't
# expose Postgres externally); the app enforces the same constraint at the
# application layer regardless. For the local docker-compose stack this is
# the host-mapped port: postgresql://directus:directus@localhost:5432/directus
# DATABASE_URL=

# Long-lived static token used by the Express server to talk to Directus as
# the narrowly-scoped "PinTogather Service" role (see
# src/permissions/definitions.ts) — never admin, never exposed to the
# browser. Generated by `npm --prefix directus run permissions:apply` on
# first run and printed to the console — paste it here and into the app's
# root .env as DIRECTUS_SERVICE_TOKEN.
# SERVICE_TOKEN=

# Comma-separated list of emails that should be granted is_admin=true on
# their directus_users row the first time they sign in via Clerk.
ADMIN_EMAILS=kipergil@gmail.com
