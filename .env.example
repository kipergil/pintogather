# --- Directus (backend data store) ---
# URL of your Directus instance. For local dev via `docker compose up -d`,
# this is http://localhost:8055.
DIRECTUS_URL=http://localhost:8055
# Static token for the narrowly-scoped "Service" role. Generated by
# `npm run directus:permissions:apply` on first run and printed to the
# console — paste it here.
DIRECTUS_SERVICE_TOKEN=

# --- Clerk (authentication) ---
# Publishable key, exposed to the browser (safe to share).
VITE_CLERK_PUBLISHABLE_KEY=
# Secret key, server-only. Read automatically by @clerk/express.
CLERK_SECRET_KEY=
# Signing secret for the /api/webhooks/clerk endpoint (from the Clerk
# Dashboard > Webhooks). Optional for local dev — without it, users are
# still synced to Directus just-in-time on their first authenticated request.
CLERK_WEBHOOK_SIGNING_SECRET=

# --- Admin ---
# Comma-separated emails granted is_admin=true the first time they sign in.
ADMIN_EMAILS=

# --- Google Maps ---
GOOGLE_MAPS_API_KEY=

# --- Server ---
PORT=5000
NODE_ENV=development
